@model IEnumerable<TaskManagementSystem.Models.TaskItem>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Task List</h2>
        <a asp-action="Create" class="btn btn-primary">Create New Task</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.DueDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(item.Status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">Edit</a>
                        @if (item.Status != "Completed")
                        {
                            <a asp-action="MarkCompleted" asp-route-id="@item.Id" class="btn btn-sm btn-success">Complete</a>
                        }
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>