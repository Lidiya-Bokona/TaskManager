@model IEnumerable<TaskManagementSystem.Models.TaskItem>

<div class="container mt-4">
    <div class="d-flex justify-content-between">
        <h2>My Tasks</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add New</a>
    </div>

    <form asp-action="Index" method="get" class="my-3 d-flex">
        <input name="searchString" class="form-control me-2" placeholder="Search tasks..." />
        <button type="submit" class="btn btn-secondary">Search</button>
    </form>

    <table class="table table-hover mt-3 shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.DueDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(item.Status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Edit</a>
                        @if(item.Status != "Completed"){
                            <a asp-action="Complete" asp-route-id="@item.Id" class="btn btn-sm btn-success">Done</a>
                        }
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
